# Port number for the backend server
PORT=5000

# MongoDB URI (local MongoDB or your MongoDB Atlas connection string)
MONGO_URI=mongodb://localhost:27017/startup-sensai

# JSON Web Token (JWT) secret key
JWT_SECRET=your_super_secret_jwt_key_here

# API Key for the AI Advisory Bot (OpenAI or Gemini API key starting with 'AIzaSy')
OPENAI_API_KEY=your_openai_or_gemini_api_key_here

# Frontend client URL
CLIENT_URL=http://localhost:5173

# Node environment
NODE_ENV=development

# Razorpay Credentials (required for mentor session booking)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
